# This .gitignore file should be placed at the root of your Unity project directory
#
# Unity Build Files and Directories
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/Temp/
/Builds/

# Memory and Recording Files
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset Store Tools
# /[Aa]ssets/AssetStoreTools*

# IDE - Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
.idea/
*.sln.iml

# IDE - Visual Studio
.vs/
.vscode/
*.sw[op]
*~
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
*.csproj
*.unityproj

# Visual Studio cache/options directory
.vs/

# Gradle cache directory
.gradle/
/Assets/Plugins/Android/gradleTemplate.properties
/Assets/Plugins/Android/mainTemplate.gradle

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pdbx

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.ipa
*.so

# Crashlytics generated file
crashlytics-build.properties

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Oculus Platform SDK
/Assets/Plugins/Android/assets/

# WebGL Build
/Build/
/TemplateData/

# Operating System Files
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
*.lnk
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Package Manager
Packages/
Assets/Packages/

# Test Assemblies
Assets/PlaymodeTestsCache/

# Backup and Temporary Files
*.bak
*.backup
*.swp
*.tmp
*~

# VS Code Extensions
.vscode/extensions/
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Misc
.env
.env.local
.env.*.local
config.local.json
